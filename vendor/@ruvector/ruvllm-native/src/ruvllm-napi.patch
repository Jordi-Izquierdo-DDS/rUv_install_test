diff --git a/crates/sona/src/napi_simple.rs b/crates/sona/src/napi_simple.rs
index 2a4692e4..35c58f24 100644
--- a/crates/sona/src/napi_simple.rs
+++ b/crates/sona/src/napi_simple.rs
@@ -215,6 +215,72 @@ impl SonaEngine {
     pub fn is_enabled(&self) -> bool {
         self.inner.is_enabled()
     }
+
+    /// Serialize engine state to JSON for persistence
+    /// @returns State JSON string that can be passed to loadState()
+    #[napi]
+    pub fn save_state(&self) -> String {
+        self.inner.coordinator().serialize_state()
+    }
+
+    /// Restore engine state from JSON
+    /// @param state_json - JSON string from saveState()
+    /// @returns Number of patterns restored
+    #[napi]
+    pub fn load_state(&self, state_json: String) -> u32 {
+        match self.inner.coordinator().load_state(&state_json) {
+            Ok(n) => n as u32,
+            Err(e) => {
+                eprintln!("SONA load_state error: {}", e);
+                0
+            }
+        }
+    }
+
+    // ─── Added by ruflo v4 rebuild — OQ-3 NAPI surface gap ──────────────────
+    // Underlying Rust symbols exist + public in v2.1.2 but lack #[napi]
+    // annotations. The 1:1 passthroughs below expose them to Node.js. Callers
+    // read getStats() before/after if they need deltas (no invented return
+    // semantics). See ruflo doc/adr/005-v4-alpha-published-npm-only.md §3.
+
+    /// Phase 11 FORGET — merge Fisher information across all EWC tasks into one
+    /// consolidated snapshot. Reduces task_count and memory footprint.
+    #[napi]
+    pub fn consolidate_tasks(&self) {
+        self.inner.coordinator().ewc().write().consolidate_all_tasks();
+    }
+
+    /// Phase 12 PRUNE — drop low-quality/stale patterns from reasoning bank.
+    /// @param min_quality   - avg_quality threshold below which a pattern is dropped
+    /// @param min_accesses  - access_count threshold (drop if below)
+    /// @param max_age_secs  - age in seconds beyond which a pattern is dropped
+    #[napi]
+    pub fn prune_patterns(&self, min_quality: f64, min_accesses: u32, max_age_secs: u32) {
+        self.inner
+            .coordinator()
+            .reasoning_bank()
+            .write()
+            .prune_patterns(min_quality as f32, min_accesses, max_age_secs as u64);
+    }
+
+    /// Fix 23 — EWC++ internal telemetry. Exposes samples_seen progress toward
+    /// the 50-sample task-boundary detection gate (ewc.rs:148), plus task_count
+    /// (non-zero after first boundary detected). Returns JSON string.
+    ///   {
+    ///     "samples_seen": u64,  // 0..∞, incremented once per background run_cycle
+    ///     "task_count":   usize, // 0 until first task_boundary detected
+    ///     "remaining_to_detection": u64  // 50 - samples_seen, saturating
+    ///   }
+    #[napi]
+    pub fn ewc_stats(&self) -> String {
+        let ewc = self.inner.coordinator().ewc().read();
+        let samples = ewc.samples_seen();
+        serde_json::json!({
+            "samples_seen": samples,
+            "task_count": ewc.task_count(),
+            "remaining_to_detection": 50u64.saturating_sub(samples),
+        }).to_string()
+    }
 }
 
