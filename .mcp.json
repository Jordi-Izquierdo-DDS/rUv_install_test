{
  "mcpServers": {
    "claude-flow": {
      "command": "npx",
      "args": ["-y", "ruflo@latest", "mcp", "start"],
      "env": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v4",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "hierarchical-mesh",
        "CLAUDE_FLOW_MEMORY_BACKEND": "better-sqlite3"
      },
      "autoStart": false
    },
    "ruvector": {
      "command": "node_modules/.bin/ruvector",
      "args": ["mcp", "start"],
      "autoStart": false
    }
  }
}
